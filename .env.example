# ============================================================
# Paperpulse — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# "dev" — uses cached pickle files to avoid repeated API calls
# "prod" — always fetches fresh data from ArXiv
PROJECT_ENV=dev

# Absolute path to the repository root on the host
PROJECT_DIR=/path/to/paperpulse

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model to use for summarisation — any OpenAI model name.
# Examples:
#   gpt-4o
#   gpt-4o-mini
#   o3-mini
OPENAI_MODEL=gpt-4o-mini

# Optional: Mixpanel analytics token for the Jekyll blog
MIXPANEL_TOKEN=
